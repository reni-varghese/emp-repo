h2("14.1 Add an explicit retry policy")
p("By default MassTransit retries transient consumer failures a small number of times immediately. For a more resilient, "
  "explicit policy with backoff, add <font face='Courier'>UseMessageRetry</font> inside the RabbitMQ configuration:")
code(
"""x.UsingRabbitMq((context, cfg) =>
{
    cfg.Host(rabbitMqConfig[\"HostName\"], rabbitMqConfig[\"VirtualHost\"], h =>
    {
        h.Username(rabbitMqConfig[\"UserName\"]!);
        h.Password(rabbitMqConfig[\"Password\"]!);
    });

    cfg.UseMessageRetry(r => r.Intervals(
        TimeSpan.FromSeconds(1),
        TimeSpan.FromSeconds(5),
        TimeSpan.FromSeconds(15)));

    cfg.ReceiveEndpoint(rabbitMqConfig[\"EmployeeQueue\"]!, e =>
    {
        e.ConfigureConsumer<EmployeeEventConsumer>(context);
    });
});"""
)
p("This retries a failed <font face='Courier'>Consume</font> call after 1s, then 5s, then 15s before the message is finally "
  "moved to the error queue.")

h2("14.2 Split EmployeeEvent into strongly-typed messages")
p("The minimal-change path (Step 2) kept a single <font face='Courier'>EmployeeEvent</font> class with an "
  "<font face='Courier'>EventType</font> string. A more idiomatic MassTransit design uses one message type per business event, "
  "so the consumer can implement multiple <font face='Courier'>IConsumer&lt;T&gt;</font> interfaces instead of branching on a string:")
code(
"""namespace EmployeeApp.Api.Events
{
    public record EmployeeCreated(int EmployeeId, string EmployeeName, DateTime OccurredAt);
    public record EmployeeDeleted(int EmployeeId, string EmployeeName, DateTime OccurredAt);
}

public class EmployeeEventConsumer :
    IConsumer<EmployeeCreated>,
    IConsumer<EmployeeDeleted>
{
    public Task Consume(ConsumeContext<EmployeeCreated> context)
    {
        _logger.LogInformation(\"Employee created: {Id} {Name}\", context.Message.EmployeeId, context.Message.EmployeeName);
        return Task.CompletedTask;
    }

    public Task Consume(ConsumeContext<EmployeeDeleted> context)
    {
        _logger.LogInformation(\"Employee deleted: {Id} {Name}\", context.Message.EmployeeId, context.Message.EmployeeName);
        return Task.CompletedTask;
    }
}"""
)
p("<font face='Courier'>EmployeeService</font> would then call "
  "<font face='Courier'>publishEndpoint.Publish(new EmployeeCreated(result.Id, result.Name, DateTime.UtcNow))</font> "
  "instead of constructing a generic <font face='Courier'>EmployeeEvent</font> with a string tag. "
  "This is a separate, optional refactor &mdash; apply it only after the core migration is stable.")

